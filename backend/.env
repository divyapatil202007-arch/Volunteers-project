# Environment Variables
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="file:./dev.db"
DIRECT_URL="file:./dev.db"

# Authentication
JWT_SECRET=supersecretjwtkey_please_change_in_production
JWT_EXPIRE=30d
REFRESH_TOKEN_SECRET=supersecretrefreshtoken_change_in_prod
REFRESH_TOKEN_EXPIRE=90d

# Cloudinary (File Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Nodemailer - SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
FROM_EMAIL=noreply@volunteerai.com
FROM_NAME=VolunteerAI

# Third Party APIs
OPENAI_API_KEY=your_openai_key
GOOGLE_MAPS_API_KEY=your_google_maps_key

# AI Server (Python Proxy)
AI_SERVER_URL=http://localhost:8000

